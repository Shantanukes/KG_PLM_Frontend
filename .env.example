# KG-VERTEX PLM — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# Backend API base URL (REQUIRED — must be HTTPS in production)
VITE_API_BASE_URL=https://your-api-domain.com

# Session idle timeout in minutes (default: 30)
VITE_SESSION_TIMEOUT_MINUTES=30

# Seconds before JWT expiry to trigger automatic silent refresh (default: 60)
VITE_TOKEN_REFRESH_BUFFER_SECONDS=60
